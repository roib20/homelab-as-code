# Set account-wide variables. These are automatically pulled in to configure the remote state bucket in the root
# root.hcl configuration.
locals {
  virtual_environment_endpoint                = "https://pve:8006/"
  virtual_environment_api_token               = "user@pam!token=00000000-0000-0000-0000-000000000000"
  virtual_environment_username                = ""
  virtual_environment_password                = ""
  virtual_environment_auth_ticket             = ""
  virtual_environment_csrf_prevention_token   = ""
}
