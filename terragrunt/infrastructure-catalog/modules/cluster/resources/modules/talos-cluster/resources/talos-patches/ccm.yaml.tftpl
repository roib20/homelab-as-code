---
machine:
  kubelet:
    extraArgs:
      cloud-provider: external
      # For security reasons, it is recommended to enable the rotation of server certificates.
      rotate-server-certificates: true
  features:
    kubernetesTalosAPIAccess:
      allowedKubernetesNamespaces:
        - kube-system
        - system-upgrade
      allowedRoles:
        - os:admin
      enabled: true
