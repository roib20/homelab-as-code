# https://docs.siderolabs.com/talos/latest/reference/configuration/block/swapvolumeconfig
---
apiVersion: v1alpha1
kind: SwapVolumeConfig
name: zswap
provisioning:
  diskSelector:
    match: 'disk.dev_path == "/dev/vdc" && disk.transport == "virtio"'
  minSize: ${swap_disk}GB
  maxSize: ${swap_disk}GB
