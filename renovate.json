{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      "managerFilePatterns": [
        "*"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+(:\\s|=)(&\\S+\\s)?(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "description": "Process OCI dependencies",
      "managerFilePatterns": [
        "/\\.yaml(?:\\.j2)?$/"
      ],
      "matchStrings": [
        "oci://(?<depName>[^:]+):(?<currentValue>\\S+)"
      ]
    }
  ],
  "extends": [
    "config:recommended",
    "customManagers:dockerfileVersions"
  ],
  "packageRules": [
    {
      "description": "Alpine Linux Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Alpine Linux",
      "groupSlug": "alpine",
      "matchPackageNames": [
        "/alpine/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "OpenTofu Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "OpenTofu",
      "groupSlug": "opentofu",
      "matchPackageNames": [
        "/opentofu/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Terragrunt Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Terragrunt",
      "groupSlug": "terragrunt",
      "matchPackageNames": [
        "/terragrunt/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Go Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Go",
      "groupSlug": "go",
      "matchPackageNames": [
        "/golang/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Task Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Task",
      "groupSlug": "task",
      "matchPackageNames": [
        "/task/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Talos Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Talos",
      "groupSlug": "talos",
      "matchPackageNames": [
        "/talos/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Kubernetes Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Kubernetes",
      "groupSlug": "kubernetes",
      "matchPackageNames": [
        "kubernetes",
        "kubernetes/kubernetes",
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Helm Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Helm",
      "groupSlug": "helm",
      "matchPackageNames": [
        "helm/helm"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Kustomize Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Kustomize",
      "groupSlug": "kustomize",
      "matchPackageNames": [
        "/kustomize/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "jq Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "jq",
      "groupSlug": "jq",
      "matchPackageNames": [
        "/jq/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Python Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Python",
      "groupSlug": "python",
      "matchPackageNames": [
        "/python/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "ttyrec Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "ttyrec",
      "groupSlug": "ttyrec",
      "matchPackageNames": [
        "/ttyrec/"
      ],
      "minimumGroupSize": 2
    },
    {
      "allowedVersions": "<10.0.0",
      "matchPackageNames": [
        "adyanth/cloudflare-operator",
        "ghcr.io/adyanth/cloudflare-operator"
      ]
    }
  ],
  "terragrunt": {
    "enabled": false
  }
}
