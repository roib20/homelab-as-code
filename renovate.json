{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "ansible-galaxy": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      "managerFilePatterns": [
        "**"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*\\S+\\s*[:=]\\s*\"?(?<currentValue>[^\"\\s]+)\"?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "description": "Process OCI dependencies",
      "managerFilePatterns": [
        "/\\.yaml(?:\\.j2)?$/"
      ],
      "matchStrings": [
        "oci://(?<depName>[^:]+):(?<currentValue>\\S+)"
      ]
    }
  ],
  "dependencyDashboard": true,
  "dependencyDashboardApproval": true,
  "dependencyDashboardTitle": "Dependency Dashboard",
  "extends": [
    "config:recommended",
    "customManagers:dockerfileVersions",
    ":disableRateLimiting"
  ],
  "packageRules": [
    {
      "description": "Alpine Linux Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Alpine Linux",
      "groupSlug": "alpine",
      "matchPackageNames": [
        "/alpine/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "cert-manager Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "cert-manager",
      "groupSlug": "cert-manager",
      "matchPackageNames": [
        "/cert-manager/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Cilium Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Cilium",
      "groupSlug": "cilium",
      "matchPackageNames": [
        "/cilium/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "CoreDNS Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "CoreDNS",
      "groupSlug": "coredns",
      "matchPackageNames": [
        "/coredns/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "External Secrets Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "External Secrets",
      "groupSlug": "external-secrets",
      "matchPackageNames": [
        "/external-secrets/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Helm Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Helm",
      "groupSlug": "helm",
      "matchPackageNames": [
        "helm/helm"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Kustomize Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Kustomize",
      "groupSlug": "kustomize",
      "matchPackageNames": [
        "kubernetes-sigs/kustomize"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Kubernetes Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Kubernetes",
      "groupSlug": "kubernetes",
      "matchPackageNames": [
        "kubernetes",
        "kubernetes/kubernetes",
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "OpenTofu and Terragrunt Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "OpenTofu and Terragrunt",
      "groupSlug": "opentofu-and-terragrunt",
      "matchPackageNames": [
        "/opentofu/",
        "/terragrunt/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Python Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Python",
      "groupSlug": "python",
      "matchPackageNames": [
        "/python/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Spegel Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Spegel",
      "groupSlug": "spegel",
      "matchPackageNames": [
        "/spegel/"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Talos Group",
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "groupName": "Talos",
      "groupSlug": "talos",
      "matchPackageNames": [
        "/talos/",
        "ghcr.io/siderolabs/installer"
      ],
      "minimumGroupSize": 2
    },
    {
      "allowedVersions": "<10.0.0",
      "matchPackageNames": [
        "adyanth/cloudflare-operator",
        "ghcr.io/adyanth/cloudflare-operator"
      ]
    }
  ],
  "terragrunt": {
    "enabled": false
  }
}
