# ExternalSecret: https://external-secrets.io/latest/api/externalsecret/
# Backing entry holds the full contents of ~/.hermes/auth.json produced by
# `hermes auth add openai-codex` (ChatGPT/Codex subscription device-code login).
---
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: hermes-auth-codex
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: bitwarden-secretsmanager
    kind: ClusterSecretStore
  target:
    name: hermes-auth-codex
    creationPolicy: Owner
    template:
      engineVersion: v2
      type: Opaque
  data:
    - secretKey: auth.json
      remoteRef:
        key: hermes-auth-codex
        conversionStrategy: Default
        decodingStrategy: None
        metadataPolicy: None
