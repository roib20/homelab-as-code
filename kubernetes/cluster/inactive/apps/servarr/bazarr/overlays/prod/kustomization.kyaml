---
{
  apiVersion: "kustomize.config.k8s.io/v1beta1",
  kind: "Kustomization",
  helmCharts: [{
    name: "bazarr",
    repo: "oci://oci.trueforge.org/truecharts",
    version: "22.1.0",
    releaseName: "bazarr",
    namespace: "media",
    valuesFile: "../../base/values.yaml",
    additionalValuesFiles: [
      "values-override.yaml",
    ],
  }],
  resources: [
    "../../base",
  ],
}
