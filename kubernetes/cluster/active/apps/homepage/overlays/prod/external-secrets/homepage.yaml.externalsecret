      remoteRef:
        key: jellyfin-secret
        conversionStrategy: Default
        decodingStrategy: None
        metadataPolicy: None
    - secretKey: HOMEPAGE_VAR_KARAKEEP_KEY
      remoteRef:
        key: HOMEPAGE_VAR_KARAKEEP_KEY
        conversionStrategy: Default
        decodingStrategy: None
        metadataPolicy: None
    - secretKey: HOMEPAGE_VAR_MEALIE_KEY
      remoteRef:
        key: mealie-secret
        conversionStrategy: Default
        decodingStrategy: None
        metadataPolicy: None
