        key: bazarr-hd-secret
        conversionStrategy: Default
        decodingStrategy: None
        metadataPolicy: None
    - secretKey: HOMEPAGE_VAR_BAZARR_UHD_KEY
      remoteRef:
        key: bazarr-uhd-secret
        conversionStrategy: Default
        decodingStrategy: None
        metadataPolicy: None
    - secretKey: HOMEPAGE_VAR_FORGEJO_KEY
      remoteRef:
        key: forgejo-secret
        conversionStrategy: Default
        decodingStrategy: None
        metadataPolicy: None
    - secretKey: HOMEPAGE_VAR_IMMICH_KEY
      remoteRef:
        key: immich-secret
        conversionStrategy: Default
        decodingStrategy: None
        metadataPolicy: None
